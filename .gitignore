# ==========================================
# 1. Rust 標準編譯過濾
# ==========================================
/target/
**/*.rs.bk

# ==========================================
# 2. Trunk & WebAssembly 前端專屬過濾
# ==========================================
# Trunk 每次建構與熱重載的暫存目錄（非常臃腫，絕對不要上傳）
/.trunk/

# Trunk 打包出來的最終網頁靜態成品目錄（HTML/WASM/JS）
/dist/

# ==========================================
# 3. 開發工具與編輯器過濾
# ==========================================
# VS Code 個人化設定（如果你有設定 target 排除 Chrome 錯誤，保留 settings.json 即可，其他過濾）
.vscode/*
!.vscode/settings.json

# 萬一未來有引入環境變數敏感資料
.env
.env.*